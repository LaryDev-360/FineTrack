# FineTrack Backend — variables d'environnement
# Copier vers .env et adapter les valeurs.

# Clé secrète Django (générer une nouvelle en production)
SECRET_KEY=your-secret-key-here

# Environnement: development | production
ENV=development

# Debug (désactiver en production)
DEBUG=True

# Hôtes autorisés (séparés par des virgules)
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de données
# — PostgreSQL (production / dev avec Docker) :
# DATABASE_URL=postgres://user:password@localhost:5432/finetrack_db
# — Si DATABASE_URL est absent, SQLite est utilisé (db.sqlite3)
# DATABASE_URL=

# CORS : origines autorisées (séparées par des virgules)
# En dev avec DEBUG=True et sans cette variable, toutes les origines sont autorisées.
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Email (OTP, mot de passe oublié)
# En dev : console (OTP affiché dans la console)
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# En prod : SMTP
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=FineTrack <noreply@example.com>

# RAG / LLM (OpenRouter)
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
# RAG_LLM_MODEL=openai/gpt-4o-mini
# RAG_EMBED_MODEL=text-embedding-3-small
# RAG_LLM_TIMEOUT_SECONDS=20
# RAG_LLM_MAX_RETRIES=2
# RAG_LLM_RETRY_BACKOFF_SECONDS=1.0
# RAG_SUPPORTED_LANGUAGES=fr,en,fon,yo
# RAG_MAX_CONTEXT_CHUNKS=6
# RAG_MIN_RELEVANCE_SCORE=0.25
